NODE_ENV=development
PORT=8001
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/trio?schema=public
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug

# Object storage (S3-compatible). Examples:
#  AWS S3:           leave S3_ENDPOINT blank, set S3_REGION + S3_BUCKET
#  Cloudflare R2:    S3_REGION=auto, S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com, S3_FORCE_PATH_STYLE=true
#  MinIO (local):    S3_REGION=us-east-1, S3_ENDPOINT=http://localhost:9000, S3_FORCE_PATH_STYLE=true
S3_REGION=us-east-1
S3_BUCKET=trio-dev
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
# Optional CDN host (e.g. https://cdn.example.com). If unset, public URL is computed from bucket+region or endpoint.
S3_PUBLIC_URL=
