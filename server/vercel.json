{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "installCommand": "cd .. && bun install --frozen-lockfile",
    "buildCommand": "mkdir -p public && printf '<!doctype html><title>API</title><p>API only. See <a href=/health>/health</a>.</p>' > public/index.html && cd .. && bun --cwd server run db:generate",
    "outputDirectory": "public",
    "functions": {
        "api/index.ts": {
            "runtime": "@vercel/node@3.2.24",
            "memory": 1024,
            "maxDuration": 30
        }
    },
    "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}

