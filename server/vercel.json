{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "installCommand": "cd .. && bun install --frozen-lockfile",
    "buildCommand": "cd .. && bun --cwd server run db:generate",
    "functions": {
        "api/index.ts": {
            "runtime": "@vercel/node@3.2.24",
            "memory": 1024,
            "maxDuration": 30
        }
    },
    "rewrites": [{ "source": "/(.*)", "destination": "/api" }]
}
